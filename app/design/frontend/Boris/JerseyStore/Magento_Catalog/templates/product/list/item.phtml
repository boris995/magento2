<?php
/**
 * Product card template for JerseyStore PLP.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 */

use Magento\Framework\App\Action\Action;

/** @var \Magento\Catalog\Model\Product $_product */
$_product = $block->getData('product');
/** @var \Magento\Catalog\Block\Product\ListProduct $_listBlock */
$_listBlock = $block->getData('list_block');
$_imageDisplayArea = $block->getData('image_display_area') ?: 'category_page_grid';
$_templateType = $block->getData('template_type') ?: \Magento\Catalog\Block\Product\ReviewRendererInterface::SHORT_VIEW;
$_outputHelper = $_listBlock->getData('outputHelper');
$_productImage = $_listBlock->getImage($_product, $_imageDisplayArea);
$_productName = $_listBlock->stripTags($_product->getName(), null, true);
$_viewModel = $block->getData('jersey_category_products');
$_priceHelper = $this->helper(\Magento\Framework\Pricing\Helper\Data::class);
$_stockData = $_viewModel ? $_viewModel->getStockData($_product) : ['is_in_stock' => null, 'qty' => null];
$_productUrl = $_viewModel ? $_viewModel->getProductUrl($_product) : $_product->getProductUrl();
?>

<article
    class="group relative flex h-full flex-col overflow-hidden border border-[#2A3447] bg-[#141A24]/90 transition duration-300 hover:-translate-y-1 hover:border-[#D4AF37] hover:shadow-2xl hover:shadow-black/30"
    id="product-item-info_<?= (int) $_product->getId() ?>"
>
    <a
        href="<?= $escaper->escapeUrl($_productUrl) ?>"
        class="relative block border-b border-[#2A3447] bg-[radial-gradient(circle_at_50%_30%,rgba(42,52,71,0.55),#0B0F19_72%)] p-4"
        tabindex="-1"
    >
        <span class="absolute left-3 top-3 z-10 bg-[#D4AF37] px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.1em] text-[#0B0F19]">
            <?= $escaper->escapeHtml($_stockData['is_in_stock'] === false ? __('Nema na stanju') : ($_product->getFinalPrice() < $_product->getPrice() ? __('Akcija') : __('Novo'))) ?>
        </span>
        <span class="absolute right-3 top-3 z-10 grid h-9 w-9 place-items-center rounded-full bg-[#0B0F19]/60 text-white backdrop-blur" aria-hidden="true"><svg class="h-5 w-5" viewBox="0 0 24 24" fill="none"><path d="M20.8 5.6a5 5 0 0 0-7.1 0L12 7.3l-1.7-1.7a5 5 0 0 0-7.1 7.1L12 21l8.8-8.3a5 5 0 0 0 0-7.1Z" stroke="currentColor" stroke-width="1.6"/></svg></span>
        <div class="aspect-[4/5] overflow-hidden bg-transparent">
            <div class="h-full w-full transition duration-500 group-hover:scale-105">
                <?= $_productImage->toHtml() ?>
            </div>
        </div>
    </a>

    <div class="flex flex-1 flex-col p-5">
        <div class="flex-1">
            <h2 class="text-lg font-black leading-snug text-white">
                <a
                    href="<?= $escaper->escapeUrl($_productUrl) ?>"
                    class="!text-white !no-underline transition hover:!text-[#D4AF37]"
                    title="<?= $escaper->escapeHtmlAttr($_productName) ?>"
                >
                    <?= /* @noEscape */ $_outputHelper->productAttribute($_product, $_product->getName(), 'name') ?>
                </a>
            </h2>

            <div class="mt-3 text-sm text-[#B7C0D1]">
                <?= $_listBlock->getReviewsSummaryHtml($_product, $_templateType) ?>
            </div>

            <div class="mt-4 text-2xl font-black text-white">
                <?= /* @noEscape */ $_priceHelper->currency($_product->getFinalPrice(), true, false) ?>
            </div>

            <?= $_listBlock->getProductDetailsHtml($_product) ?>

            <div class="mt-4 flex gap-2" aria-label="<?= $escaper->escapeHtmlAttr(__('Dostupne veličine')) ?>">
                <?php foreach (['S', 'M', 'L', 'XL', 'XXL'] as $size): ?>
                    <span class="grid h-8 min-w-8 flex-1 place-items-center rounded border <?= $size === 'M' ? 'border-[#D4AF37] bg-[#D4AF37] text-[#0B0F19]' : 'border-[#2A3447] text-[#B7C0D1]' ?> text-[10px] font-black"><?= $escaper->escapeHtml($size) ?></span>
                <?php endforeach; ?>
            </div>
        </div>

        <div class="mt-5 flex flex-col gap-3">
            <?php if ($_product->isSaleable()): ?>
                <?php $_postParams = $_listBlock->getAddToCartPostParams($_product); ?>
                <form
                    data-role="tocart-form"
                    data-product-sku="<?= $escaper->escapeHtmlAttr($_product->getSku()) ?>"
                    action="<?= $escaper->escapeUrl($_postParams['action']) ?>"
                    data-mage-init='{"catalogAddToCart": {}}'
                    method="post"
                >
                    <input type="hidden" name="product" value="<?= (int) $_postParams['data']['product'] ?>" />
                    <input
                        type="hidden"
                        name="<?= /* @noEscape */ Action::PARAM_NAME_URL_ENCODED ?>"
                        value="<?= /* @noEscape */ $_postParams['data'][Action::PARAM_NAME_URL_ENCODED] ?>"
                    />
                    <?= $_listBlock->getBlockHtml('formkey') ?>
                    <button
                        type="submit"
                        title="<?= $escaper->escapeHtmlAttr(__('Add to Cart')) ?>"
                        class="category-addtocart w-full border border-[#D4AF37] bg-transparent px-5 py-3 text-xs font-black uppercase tracking-[0.1em] text-[#D4AF37] transition hover:bg-[#E6C55A] hover:text-[#0B0F19]"
                    >
                        <span><?= $escaper->escapeHtml(__('Dodaj u korpu')) ?></span>
                    </button>
                </form>
            <?php else: ?>
                <div class="border border-[#2A3447] px-5 py-3 text-center text-sm font-black uppercase tracking-[0.1em] text-[#B7C0D1]">
                    <?= $escaper->escapeHtml($_product->isAvailable() ? __('Dostupno') : __('Nema na stanju')) ?>
                </div>
            <?php endif; ?>

            <a
                href="<?= $escaper->escapeUrl($_productUrl) ?>"
                class="text-center text-sm font-black !text-[#B7C0D1] !no-underline transition hover:!text-white"
            >
                <?= $escaper->escapeHtml(__('Detalji proizvoda')) ?>
            </a>
        </div>
    </div>
</article>
