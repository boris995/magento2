$categoryCrops = ['object-[72%_46%]', 'object-[50%_42%]', 'object-[30%_50%]', 'object-[84%_54%]', 'object-[64%_48%]', 'object-[38%_50%]'];
$benefits = [
    [
        'title' => 'Brza Dostava',
        'eyebrow' => 'Pakujemo isti dan',
        'copy' => 'Tvoj dres spremamo odmah nakon narudžbe, pažljivo ga pakujemo i šaljemo bez nepotrebnog čekanja. Idealno kada treba stići prije derbija, poklona ili vikend utakmice.',
