<?php
/**
 * Homepage product card for JerseyStore.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 */

/** @var \Magento\Catalog\Model\Product $product */
$product = $block->getData('product');
/** @var \Magento\Framework\Pricing\Helper\Data $priceHelper */
$priceHelper = $block->getData('price_helper');
/** @var \Magento\Catalog\Helper\Image $imageHelper */
$imageHelper = $block->getData('image_helper');

if (!$product) {
    return;
}

$productName = (string) $product->getName();
$urlKey = trim((string) $product->getUrlKey(), '/');
$productUrl = $urlKey !== ''
    ? $block->getUrl('', ['_direct' => $urlKey . '.html'])
    : (string) $product->getProductUrl();
$imageUrl = $imageHelper
    ? $imageHelper->init($product, 'product_page_image_medium')->constrainOnly(true)->keepAspectRatio(true)->keepFrame(false)->getUrl()
    : '';
$price = $priceHelper
    ? $priceHelper->currency((float) $product->getFinalPrice(), true, false)
    : (string) $product->getFinalPrice();
$shortDescription = trim((string) $product->getShortDescription());
$cleanDescription = $shortDescription !== '' ? strip_tags($shortDescription) : __('Premium football jersey ready for matchday.');
?>

<article class="group min-w-[76vw] snap-start sm:min-w-[320px] lg:min-w-0">
    <a
        href="<?= $escaper->escapeUrl($productUrl) ?>"
        class="block overflow-hidden rounded-[22px] bg-white shadow-sm ring-1 ring-neutral-200 transition duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/10 hover:ring-red-500/40 lg:rounded-none"
        aria-label="<?= $escaper->escapeHtmlAttr($productName) ?>"
    >
        <div class="relative h-[330px] overflow-hidden bg-gradient-to-br from-neutral-100 via-white to-neutral-200 lg:h-80">
            <span class="absolute left-4 top-4 z-10 bg-neutral-950 px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.16em] text-white">
                <?= $escaper->escapeHtml(__('In stock')) ?>
            </span>

            <span class="absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/95 text-neutral-950 shadow-sm transition group-hover:bg-red-600 group-hover:text-white">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>

            <?php if ($imageUrl): ?>
                <img
                    src="<?= $escaper->escapeUrl($imageUrl) ?>"
                    alt="<?= $escaper->escapeHtmlAttr($productName) ?>"
                    class="h-full w-full object-cover object-center transition duration-500 group-hover:scale-105"
                    loading="lazy"
                />
            <?php else: ?>
                <div class="flex h-full items-center justify-center px-8 text-center text-sm font-black uppercase tracking-[0.18em] text-neutral-400">
                    <?= $escaper->escapeHtml(__('No image')) ?>
                </div>
            <?php endif; ?>
        </div>

        <div class="p-5">
            <div class="flex items-start justify-between gap-4">
                <h3 class="text-base font-black leading-snug text-neutral-950 transition group-hover:text-red-700">
                    <?= $escaper->escapeHtml($productName) ?>
                </h3>
                <p class="shrink-0 text-sm font-black text-neutral-950">
                    <?= /* @noEscape */ $price ?>
                </p>
            </div>

            <p class="mt-3 line-clamp-2 text-sm leading-6 text-neutral-600">
                <?= $escaper->escapeHtml($cleanDescription) ?>
            </p>

            <div class="mt-5 flex items-center justify-between border-t border-neutral-200 pt-4">
                <span class="text-xs font-black uppercase tracking-[0.16em] text-neutral-950">
                    <?= $escaper->escapeHtml(__('Shop now')) ?>
                </span>
                <span class="h-px w-10 bg-red-600 transition group-hover:w-16"></span>
            </div>
        </div>
    </a>
</article>
