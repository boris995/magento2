<script>
require(['jquery'], function ($) {
    var $root = $('[data-category-filters]');
    var $cards = $('[data-product-card]');
    var $search = $root.find('[data-filter-search]');
    var $sort = $root.find('[data-filter-sort]');
    var $stock = $root.find('[data-filter-stock]');
    var $reset = $root.find('[data-filter-reset]');
    var $count = $root.find('[data-filter-count]');
    var $empty = $('[data-filter-empty]');

    function applyFilters() {
        var query = ($search.val() || '').toString().toLowerCase().trim();
        var stockOnly = $stock.is(':checked');
        var visibleCount = 0;

        $cards.each(function () {
            var $card = $(this);
            var matchesSearch = !query || ($card.data('product-name') || '').toString().indexOf(query) !== -1;
            var matchesStock = !stockOnly || $card.data('product-stock').toString() === '1';
            var isVisible = matchesSearch && matchesStock;

            $card.toggleClass('hidden', !isVisible);
            if (isVisible) {
                visibleCount++;
            }
        });

        sortCards();
        $empty.toggleClass('hidden', visibleCount !== 0);
        $count.text(visibleCount + ' <?= $escaper->escapeJs(__('proizvoda prikazano')) ?>');
    }

    function sortCards() {
        var sortValue = $sort.val();
        var $grid = $cards.first().parent();
        var sortedCards = $cards.get().sort(function (a, b) {
            var $a = $(a);
            var $b = $(b);

            if (sortValue === 'name-asc') {
                return ($a.data('product-name') || '').toString().localeCompare(($b.data('product-name') || '').toString());
            }

            if (sortValue === 'price-asc') {
                return parseFloat($a.data('product-price')) - parseFloat($b.data('product-price'));
            }

            if (sortValue === 'price-desc') {
                return parseFloat($b.data('product-price')) - parseFloat($a.data('product-price'));
            }

            return parseInt($a.data('default-order'), 10) - parseInt($b.data('default-order'), 10);
        });

        $.each(sortedCards, function (_, card) {
            $grid.append(card);
        });
    }

    $search.on('input', applyFilters);
    $sort.on('change', applyFilters);
    $stock.on('change', applyFilters);
    $reset.on('click', function () {
        $search.val('');
        $sort.val('default');
        $stock.prop('checked', false);
        applyFilters();
    });
});
</script>
