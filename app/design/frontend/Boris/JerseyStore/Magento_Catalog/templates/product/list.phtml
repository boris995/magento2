<?php
$category = $block->getLayer()->getCurrentCategory();
$viewModel = $block->getData('jersey_category_products');
$products = ($category && $viewModel) ? $viewModel->getAssignedProducts($category) : [];
$outputHelper = $block->getData('outputHelper') ?: $this->helper(\Magento\Catalog\Helper\Output::class);
$categoryHelper = $this->helper(\Magento\Catalog\Helper\Category::class);
$categoryName = $category ? (string)$category->getName() : (string)__('Products');
$categoryDescription = $category ? (string)$category->getDescription() : '';
$categoryDescriptionHtml = $category && $categoryDescription !== ''
    ? $outputHelper->categoryAttribute($category, $categoryDescription, 'description')
    : '';
$categoryImageUrl = '';
$categoryLinks = [];
$collectCategoryLinks = function ($categoryItems) use (&$categoryLinks): void {
    foreach ($categoryItems as $categoryItem) {
        if (!$categoryItem->getIsActive()) {
            continue;
        }

        $categoryLinks[] = [
            'name' => (string)$categoryItem->getName(),
            'url' => (string)$categoryItem->getUrl(),
            'is_current' => false,
        ];
    }
};

if ($category) {
    try {
        $categoryImageUrl = (string)$category->getImageUrl();
    } catch (\Exception $exception) {
        $categoryImageUrl = '';
    }

    $children = $category->getChildrenCategories();
    if ($children && count($children)) {
        $collectCategoryLinks($children);
    }
}

if (!$categoryLinks) {
    $collectCategoryLinks($categoryHelper->getStoreCategories(false, true, true));
}

foreach ($categoryLinks as &$categoryLink) {
    $categoryLink['is_current'] = trim((string)$categoryLink['url'], '/') === trim((string)$block->getUrl('*/*/*', ['_current' => true, '_use_rewrite' => true]), '/');
}
unset($categoryLink);
