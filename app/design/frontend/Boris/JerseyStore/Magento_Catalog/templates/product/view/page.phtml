$_galleryImages = $_product ? $_product->getMediaGalleryImages() : null;
$_heroImage = $_product
    ? $_imageHelper->init($_product, 'product_page_image_large')->keepFrame(false)->getUrl()
    : '';
$_thumbnailImage = $_product
    ? $_imageHelper->init($_product, 'product_page_image_small')->keepFrame(false)->getUrl()
    : '';
$_galleryItems = [];

if ($_galleryImages && $_galleryImages->getSize()) {
    foreach ($_galleryImages as $_image) {
        if (count($_galleryItems) >= 4) {
            break;
        }

        $_galleryItems[] = [
            'url' => (string) $_image->getUrl(),
            'label' => (string) ($_image->getLabel() ?: $_productName),
        ];
    }
}

if (!count($_galleryItems) && $_heroImage) {
    $_galleryItems[] = [
        'url' => $_heroImage,
        'label' => $_productName,
    ];
}
