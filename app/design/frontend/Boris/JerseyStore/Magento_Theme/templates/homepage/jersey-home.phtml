        'note' => 'Siguran checkout, jasna potvrda i podrška ako zatreba pomoć.',
        'emoji' => '🔒',
        'icon' => 'lock',
    ],
    [
        'title' => 'Zamjena Veličine',
        'eyebrow' => 'Fit mora biti pravi',
        'copy' => 'Ako veličina ne odgovara, proces zamjene je jednostavan. Želimo da dres stoji dobro, da se nosi udobno i da izgleda spremno za tribinu, trening ili svaki dan.',
        'note' => 'Brza komunikacija i jasni koraci za zamjenu bez komplikacija.',
        'emoji' => '🔁',
        'icon' => 'refresh',
    ],
    [
        'title' => 'Originalni Proizvodi',
        'eyebrow' => 'Pažljivo odabrano',
        'copy' => 'Svaki model biramo sa fokusom na izgled, materijal i detalje koje navijači primijete. Dobijaš dres koji izgleda ozbiljno i osjeća se dobro čim ga obučeš.',
        'note' => 'Kvalitetni modeli za klubove, reprezentacije i retro kolekcije.',
        'emoji' => '🛡️',
        'icon' => 'shield',
    ],
];

$objectManager = ObjectManager::getInstance();
$storeManager = $objectManager->get(StoreManagerInterface::class);
$productCollectionFactory = $objectManager->get(ProductCollectionFactory::class);
$categoryCollectionFactory = $objectManager->get(CategoryCollectionFactory::class);
$stockHelper = $objectManager->get(Stock::class);
$priceHelper = $objectManager->get(PriceHelper::class);
$imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);
$store = $storeManager->getStore();
$storeId = (int) $store->getId();
$rootCategoryId = (int) $store->getRootCategoryId();

$categoryCollection = $categoryCollectionFactory->create();
$categoryCollection
    ->setStoreId($storeId)
    ->addAttributeToSelect(['name', 'description', 'image', 'url_key', 'url_path', 'is_active'])
    ->addAttributeToFilter('is_active', 1)
    ->addFieldToFilter('parent_id', $rootCategoryId)
    ->addAttributeToSort('position', 'ASC');

$categories = [];
$categoryIndex = 0;
foreach ($categoryCollection as $category) {
    $categoryProductCollection = $productCollectionFactory->create();
    $categoryProductCollection
        ->addAttributeToFilter('status', Status::STATUS_ENABLED)
        ->addStoreFilter($storeId)
        ->addCategoriesFilter(['in' => [(int) $category->getId()]]);

    $categoryImage = (string) $category->getImageUrl();
    $categoryPath = trim((string) ($category->getUrlPath() ?: $category->getUrlKey()), '/');
    $description = trim(strip_tags((string) $category->getDescription()));
    $shortDescription = function_exists('mb_substr')
        ? mb_substr($description, 0, 150)
        : substr($description, 0, 150);

    $categories[] = [
        'title' => (string) $category->getName(),
        'copy' => $description !== ''
            ? $shortDescription
            : 'Pogledaj aktivne proizvode iz ove kategorije i pronađi dres koji najbolje odgovara tvom stilu.',
        'url' => $categoryPath !== '' ? $block->getUrl($categoryPath) : '#',
        'image' => $categoryImage !== '' ? $categoryImage : $image,
        'crop' => $categoryCrops[$categoryIndex % count($categoryCrops)],
        'meta' => 'Magento kategorija',
        'active_count' => (int) $categoryProductCollection->getSize(),
    ];
    $categoryIndex++;
}

$products = $productCollectionFactory->create();
$products
    ->addAttributeToSelect(['name', 'small_image', 'image', 'price', 'special_price', 'short_description', 'url_key'])
    ->addAttributeToFilter('status', Status::STATUS_ENABLED)
    ->addAttributeToFilter('visibility', [
        'in' => [
            Visibility::VISIBILITY_IN_CATALOG,
            Visibility::VISIBILITY_IN_SEARCH,
            Visibility::VISIBILITY_BOTH,
        ],
    ])
    ->addStoreFilter($storeId)
    ->setOrder('created_at', 'DESC')
    ->setPageSize(6)
    ->setCurPage(1);

$stockHelper->addInStockFilterToCollection($products);
?>

