<script>
require(['jquery'], function ($) {
    var activeCategory = '';
    var $cards = $('[data-product-card]');
    var $categoryButtons = $('[data-category-filter]');
    var $search = $('[data-product-search]');
    var $sort = $('[data-product-sort]');
    var $stock = $('[data-stock-filter]');
    var $reset = $('[data-reset-filters]');
    var $count = $('[data-product-count]');
    var $empty = $('[data-empty-products]');
    var $grid = $('[data-product-grid]');

    function applyFilters() {
        var query = ($search.val() || '').toString().toLowerCase().trim();
        var stockOnly = $stock.is(':checked');
        var visibleCount = 0;

        $cards.each(function () {
            var $card = $(this);
            var name = ($card.data('product-name') || '').toString();
            var categories = ($card.data('product-categories') || '').toString().split(',');
            var inCategory = !activeCategory || categories.indexOf(activeCategory) !== -1;
            var matchesSearch = !query || name.indexOf(query) !== -1;
            var matchesStock = !stockOnly || $card.data('product-stock').toString() === '1';
            var visible = inCategory && matchesSearch && matchesStock;

            $card.toggleClass('hidden', !visible);
            if (visible) {
                visibleCount++;
            }
        });

        sortProducts();
        $empty.toggleClass('hidden', visibleCount !== 0);
        $count.text(visibleCount + ' <?= $escaper->escapeJs(__('proizvoda prikazano')) ?>');
    }

    function sortProducts() {
        var sortValue = $sort.val();
        var sortedCards = $cards.get().sort(function (a, b) {
            var $a = $(a);
            var $b = $(b);

            if (sortValue === 'name-asc') {
                return ($a.data('product-name') || '').toString().localeCompare(($b.data('product-name') || '').toString());
            }

            if (sortValue === 'price-asc') {
                return parseFloat($a.data('product-price')) - parseFloat($b.data('product-price'));
            }

            if (sortValue === 'price-desc') {
                return parseFloat($b.data('product-price')) - parseFloat($a.data('product-price'));
            }

            return parseInt($a.data('default-order'), 10) - parseInt($b.data('default-order'), 10);
        });

        $.each(sortedCards, function (_, card) {
            $grid.append(card);
        });
    }

    $categoryButtons.on('click', function () {
        var $button = $(this);
        var nextCategory = $button.data('category-filter').toString();
        activeCategory = activeCategory === nextCategory ? '' : nextCategory;

        $categoryButtons.removeClass('border-[#d60000] bg-[#d60000] text-white').addClass('border-black/10 bg-white');
        if (activeCategory) {
            $button.removeClass('border-black/10 bg-white').addClass('border-[#d60000] bg-[#d60000] text-white');
        }

        applyFilters();
    });

    $search.on('input', applyFilters);
    $sort.on('change', applyFilters);
    $stock.on('change', applyFilters);
    $reset.on('click', function () {
        activeCategory = '';
        $search.val('');
        $sort.val('default');
        $stock.prop('checked', false);
        $categoryButtons.removeClass('border-[#d60000] bg-[#d60000] text-white').addClass('border-black/10 bg-white');
        applyFilters();
    });
});
</script>
