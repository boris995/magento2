    ? trim((string) $_outputHelper->productAttribute($_product, $_description, 'description'))
    : '';
$_finalPrice = $_product ? (float) $_product->getFinalPrice() : 0;
$_regularPrice = $_product ? (float) $_product->getPrice() : 0;
