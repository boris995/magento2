<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="header.container" remove="true"/>
        <referenceBlock name="navigation.sections" remove="true"/>
        <referenceBlock name="store.menu" remove="true"/>
        <referenceBlock name="catalog.topnav" remove="true"/>
        <referenceContainer name="footer" remove="true"/>
        <referenceBlock name="form.subscribe" remove="true"/>
        <referenceBlock name="absolute_footer" remove="true"/>

        <referenceContainer name="page.wrapper">
            <block class="Magento\Framework\View\Element\Template"
                   name="jersey.custom.header"
                   template="Magento_Theme::header/jersey-header.phtml"
                   before="-"/>
        </referenceContainer>

        <referenceContainer name="footer-container">
            <block class="Magento\Newsletter\Block\Subscribe"
                   name="jersey.custom.footer"
                   template="Magento_Theme::footer/jersey-footer.phtml"/>
        </referenceContainer>
    </body>
</page>
