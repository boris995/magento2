<?php
/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */

use Magento\Catalog\Model\ResourceModel\Category\CollectionFactory as CategoryCollectionFactory;
use Magento\Framework\App\ObjectManager;
use Magento\Store\Model\StoreManagerInterface;

$objectManager = ObjectManager::getInstance();
$storeManager = $objectManager->get(StoreManagerInterface::class);
$categoryCollectionFactory = $objectManager->get(CategoryCollectionFactory::class);
$store = $storeManager->getStore();
$rootCategoryId = (int) $store->getRootCategoryId();
$storeId = (int) $store->getId();

$categoryNavItems = [];
$categoryCollection = $categoryCollectionFactory->create();
$categoryCollection
    ->setStoreId($storeId)
    ->addAttributeToSelect(['name', 'url_key', 'url_path', 'is_active'])
    ->addAttributeToFilter('is_active', 1)
    ->addFieldToFilter('parent_id', $rootCategoryId)
    ->addAttributeToSort('position', 'ASC')
    ->setPageSize(4);

foreach ($categoryCollection as $category) {
    $categoryPath = trim((string) ($category->getUrlPath() ?: $category->getUrlKey()), '/');

    if ($categoryPath === '') {
        continue;
    }

    $categoryNavItems[] = [
        'label' => __((string) $category->getName()),
        'href' => $block->getUrl($categoryPath),
    ];
}

$navItems = [
    ['label' => __('Home'), 'href' => $block->getUrl('')],
];
$navItems = array_merge(
    $navItems,
    $categoryNavItems,
    [
        ['label' => __('Kategorije'), 'href' => $block->getUrl('category-page')],
        ['label' => __('O nama'), 'href' => $block->getUrl('about-us')],
        ['label' => __('Kontakt'), 'href' => $block->getUrl('contact-page')],
    ]
);
