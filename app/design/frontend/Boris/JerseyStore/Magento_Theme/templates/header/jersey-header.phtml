<?php
/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */
/** @var \Magento\Catalog\Helper\Category $categoryHelper */

$categoryHelper = $this->helper(\Magento\Catalog\Helper\Category::class);
$storeCategories = $categoryHelper->getStoreCategories(true, false, true);
$categoryNav = [];
$getCleanCategoryUrl = static function ($category) use ($block): string {
    $path = trim((string)($category->getUrlPath() ?: $category->getUrlKey()), '/');

    return $path !== '' ? $block->getUrl($path) : '#';
};

foreach ($storeCategories as $category) {
    if (!$category->getIsActive() || !$category->getIncludeInMenu()) {
        continue;
    }

    $categoryNav[] = [
        'label' => $category->getName(),
        'href' => $getCleanCategoryUrl($category),
    ];
}

$mainNav = [
    ['label' => __('Home'), 'href' => $block->getUrl('')],
    ['label' => __('Categories'), 'href' => $block->getUrl('categories')],
];
$mainNav = array_merge($mainNav, $categoryNav);
$featuredNav = array_slice($categoryNav, 0, 3);
?>

