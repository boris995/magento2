    ['title' => 'Klubovi', 'copy' => 'Najnoviji domaći i gostujući dresovi.', 'href' => 'klubovi', 'crop' => 'object-[72%_46%]'],
    ['title' => 'Reprezentacije', 'copy' => 'Dresovi za turnire i velike utakmice.', 'href' => 'reprezentacije', 'crop' => 'object-[50%_42%]'],
    ['title' => 'Retro Dresovi', 'copy' => 'Klasici inspirisani legendarnim sezonama.', 'href' => 'retro-dresovi', 'crop' => 'object-[30%_50%]'],
    ['title' => 'Dječiji Dresovi', 'copy' => 'Lagani modeli za najmlađe navijače.', 'href' => 'djeciji-dresovi', 'crop' => 'object-[84%_54%]'],
];
$benefits = [
    ['title' => 'Brza Dostava', 'copy' => 'Pakovanje i slanje bez čekanja.'],
    ['title' => 'Sigurno Plaćanje', 'copy' => 'Zaštićena kupovina svaki put.'],
    ['title' => 'Zamjena Veličine', 'copy' => 'Jednostavna zamjena ako fit nije pravi.'],
    ['title' => 'Originalni Proizvodi', 'copy' => 'Pažljivo odabrani modeli za navijače.'],
];

$objectManager = ObjectManager::getInstance();
$storeManager = $objectManager->get(StoreManagerInterface::class);
$productCollectionFactory = $objectManager->get(CollectionFactory::class);
$stockHelper = $objectManager->get(Stock::class);
$priceHelper = $objectManager->get(PriceHelper::class);
$imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);

$products = $productCollectionFactory->create();
$products
    ->addAttributeToSelect(['name', 'small_image', 'image', 'price', 'special_price', 'short_description', 'url_key'])
    ->addAttributeToFilter('status', Status::STATUS_ENABLED)
    ->addAttributeToFilter('visibility', [
        'in' => [
            Visibility::VISIBILITY_IN_CATALOG,
            Visibility::VISIBILITY_IN_SEARCH,
            Visibility::VISIBILITY_BOTH,
        ],
    ])
    ->addStoreFilter((int) $storeManager->getStore()->getId())
    ->setOrder('created_at', 'DESC');

$stockHelper->addInStockFilterToCollection($products);
?>

