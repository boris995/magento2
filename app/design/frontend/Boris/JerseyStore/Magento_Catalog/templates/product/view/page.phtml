<script>
require(['jquery'], function ($) {
    var $mainImage = $('#jersey-pdp-main-image');
    var $thumbs = $('.js-pdp-thumb');

    $thumbs.on('click', function () {
        var $thumb = $(this);
        var imageUrl = $thumb.data('full-image');

        if (!imageUrl || !$mainImage.length) {
            return;
        }

        $mainImage.attr('src', imageUrl);
        $thumbs.removeClass('border-[#6d3df5] shadow-[0_0_0_1px_#6d3df5]').addClass('border-white/15');
        $thumb.removeClass('border-white/15').addClass('border-[#6d3df5] shadow-[0_0_0_1px_#6d3df5]');
    });

    $('.js-qty-minus, .js-qty-plus').on('click', function () {
        var $qty = $('#qty');
        var currentValue = parseFloat($qty.val()) || 1;
        var nextValue = $(this).hasClass('js-qty-plus') ? currentValue + 1 : Math.max(1, currentValue - 1);

        $qty.val(nextValue).trigger('change');
    });

    $('.js-pdp-tab').on('click', function () {
        var $tab = $(this);
        var target = $tab.data('tab-target');

        if (!target || !$('#' + target).length) {
            return;
        }

        $('.js-pdp-tab')
            .removeClass('border-[#6d3df5] bg-[#6d3df5] text-white shadow-sm')
            .addClass('border-transparent text-white/55')
            .attr('aria-selected', 'false');

        $tab
            .removeClass('border-transparent text-white/55')
            .addClass('border-[#6d3df5] bg-[#6d3df5] text-white shadow-sm')
            .attr('aria-selected', 'true');

        $('.js-pdp-tab-panel').addClass('hidden');
        $('#' + target).removeClass('hidden');
    });
});
</script>

