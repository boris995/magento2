$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$categoryHelper = $this->helper(\Magento\Catalog\Helper\Category::class);
$imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);
$priceHelper = $this->helper(\Magento\Framework\Pricing\Helper\Data::class);
$productCollectionFactory = $objectManager->get(\Magento\Catalog\Model\ResourceModel\Product\CollectionFactory::class);
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$storeId = (int)$storeManager->getStore()->getId();
$categories = [];
$products = [];
$cardStyles = [
    ['accent' => '#ff2b2b', 'scene' => 'flares'],
    ['accent' => '#f5b21b', 'scene' => 'stars'],
    ['accent' => '#ff2b2b', 'scene' => 'retro'],
    ['accent' => '#2f68ff', 'scene' => 'kids'],
];
$collectCategories = function ($categoryItems) use (&$collectCategories, &$categories, $cardStyles): void {
    foreach ($categoryItems as $categoryItem) {
        if (!$categoryItem->getIsActive()) {
            continue;
        }

        $style = $cardStyles[count($categories) % count($cardStyles)];
        $description = trim(strip_tags((string)$categoryItem->getDescription()));

        $categories[] = [
            'id' => (int)$categoryItem->getId(),
            'title' => strtoupper((string)$categoryItem->getName()),
            'name' => (string)$categoryItem->getName(),
            'copy' => $description !== ''
                ? mb_substr($description, 0, 120)
                : (string)__('Pogledaj dostupne fudbalske dresove u ovoj kategoriji.'),
            'button' => (string)__('Pogledaj kategoriju'),
            'href' => (string)$categoryItem->getUrl(),
            'accent' => $style['accent'],
            'scene' => $style['scene'],
        ];

        $children = $categoryItem->getChildrenCategories();
        if ($children && count($children)) {
            $collectCategories($children);
        }
    }
};

$collectCategories($categoryHelper->getStoreCategories(false, true, true));

$productCollection = $productCollectionFactory->create();
$productCollection
    ->addAttributeToSelect(['name', 'price', 'small_image', 'thumbnail', 'url_key', 'status', 'visibility'])
    ->addStoreFilter($storeId)
    ->addAttributeToFilter('status', 1)
    ->addAttributeToFilter('visibility', ['in' => [2, 3, 4]])
    ->setPageSize(24)
    ->setCurPage(1);

foreach ($productCollection as $product) {
    $categoryIds = array_map('intval', $product->getCategoryIds());
    $products[] = [
        'id' => (int)$product->getId(),
        'name' => (string)$product->getName(),
        'url' => (string)$product->getProductUrl(),
        'price' => (float)$product->getFinalPrice(),
        'image' => (string)$imageHelper->init($product, 'category_page_grid')->keepFrame(false)->getUrl(),
        'is_saleable' => (bool)$product->isSaleable(),
        'category_ids' => $categoryIds,
    ];
}

